# ============================================================
# Decision Companion System - Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# The .env file is excluded from Git (see .gitignore).
# Never commit your real API keys to the repository.
# ============================================================

# --- Gemini API Key (Required for AI criteria classification) ---
# Obtain a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDqAPpMeXHmRE52yk0fQ8oq7Qb0h4uJAKo

# --- OpenAI API Key (Optional - used as fallback if Gemini rate-limits) ---
# Obtain a key at: https://platform.openai.com/api-keys
# If left blank, the app will only use Gemini and skip the fallback.
OPENAI_API_KEY=your_openai_api_key_here
